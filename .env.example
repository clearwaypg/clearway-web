# =========================================================
# Clearway — environment variables
#
# Copy this file to `.env.local` and fill in the real values. `.env*` files are
# gitignored (only this example is committed), so no real key is ever versioned.
# On Vercel, set the same three variables in the project settings.
# =========================================================

# Resend API key, used server-side by /api/enquiry to send the "For clubs"
# enquiry form. Server-only — never prefix it with NEXT_PUBLIC_.
# Create one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From address for outgoing mail. Its domain must be verified in Resend
# (https://resend.com/domains) or the send is rejected.
EMAIL_FROM=no-reply@clearwayperformancegroup.com

# Where enquiries are delivered. Accepts several comma-separated addresses.
EMAIL_TO=hello@clearwayperformancegroup.com
